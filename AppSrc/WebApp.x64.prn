36597>>>>>>>    //
36597>>>>>>>    Function StringToTime DateTime dtTime String sTimeString Returns DateTime
36599>>>>>>>        String sHours sMinutes sSeconds
36599>>>>>>>        
36599>>>>>>>        //  Extract parts
36599>>>>>>>        Move (Mid(sTimeString, 2, 1)) to sHours
36600>>>>>>>        Move (Mid(sTimeString, 2, 4)) to sMinutes
36601>>>>>>>        Move (Mid(sTimeString, 2, 7)) to sSeconds
36602>>>>>>>        
36602>>>>>>>        //  Set to DateTime
36602>>>>>>>        Move (DateSetHour(dtTime, (Integer(sHours)))) to dtTime
36603>>>>>>>        Move (DateSetMinute(dtTime, (Integer(sMinutes)))) to dtTime
36604>>>>>>>        Move (DateSetSecond(dtTime, (Integer(sSeconds)))) to dtTime
36605>>>>>>>        
36605>>>>>>>        Function_Return dtTime
36606>>>>>>>    End_Function
