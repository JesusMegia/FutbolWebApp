36581>>>>>>>    //
36581>>>>>>>    //  Converts the given time to an string that can be saved in the database.
36581>>>>>>>    //
36581>>>>>>>    //  Params:
36581>>>>>>>    //      dtTime  Time to convert
36581>>>>>>>    //  Returns:
36581>>>>>>>    //      String with "HH:MM:SS" format
36581>>>>>>>    //
36581>>>>>>>    Function TimeToString DateTime dtTime Returns String
36583>>>>>>>        String sHours sMinutes sSeconds
36583>>>>>>>        
36583>>>>>>>        //  Extract parts
36583>>>>>>>        Move (String(DateGetHour(dtTime))) to sHours
36584>>>>>>>        Move (String(DateGetMinute(dtTime))) to sMinutes
36585>>>>>>>        Move (String(DateGetSecond(dtTime))) to sSeconds
36586>>>>>>>        
36586>>>>>>>        //  Fill out with 0
36586>>>>>>>        If (Length(sHours) = 1) ;            Move ("0" + sHours) to sHours
36589>>>>>>>        If (Length(sMinutes) = 1) ;            Move ("0" + sMinutes) to sMinutes
36592>>>>>>>        If (Length(sSeconds) = 1) ;            Move ("0" + sSeconds) to sSeconds
36595>>>>>>>        
36595>>>>>>>        Function_Return (sHours + ":" + sMinutes + ":" + sSeconds)
36596>>>>>>>    End_Function
36597>>>>>>>    
36597>>>>>>>    //
36597>>>>>>>    //  Sets the time of the datetime variable to the time in the string.
